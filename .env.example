# Скопируйте этот файл в .env и впишите значения.
# .env в .gitignore — секреты в репозиторий не попадают.

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456789:AAArandom_token_from_BotFather

# Базовый адрес Mini App (раздаётся вашим веб-сервером, напр. Caddy по HTTPS).
# Нужен, чтобы в чате показывалась кнопка «Открыть приложение» и работал синхрон.
# Без него бот работает как обычный диалог (без Mini App-кнопок).
# Пример:  WEBAPP_BASE=https://example.sslip.io
WEBAPP_BASE=

# Разрешённый CORS-origin для sync-API (тот же домен Mini App).
# За reverse-proxy (same-origin) можно НЕ задавать — тогда CORS-заголовки не шлются.
# Пример:  ISSA_API_ORIGIN=https://example.sslip.io
ISSA_API_ORIGIN=

# Лимит запросов к sync-API на пользователя (скользящее окно). По умолчанию
# 60 запросов / 60 сек. 0 — отключить лимит. Превышение → HTTP 429.
# ISSA_RATE_MAX=60
# ISSA_RATE_WINDOW=60

# (опционально) Переопределить отдельные URL Mini App, если они на разных путях:
# WEBAPP_HOME_URL=https://example.sslip.io/
# WEBAPP_QUIZ_URL=https://example.sslip.io/quiz.html
# WEBAPP_URL=https://example.sslip.io/calc.html
